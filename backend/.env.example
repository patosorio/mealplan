# backend/.env.example — commit this file, NEVER commit the real .env
# Copy to .env and fill in values before running locally or deploying.
# Every key here maps 1:1 to a Secret Manager secret named patrieats-{key-name}.

# ── AI APIs ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional: override the Claude model (default: claude-3-haiku-20240307)
# CLAUDE_MODEL=claude-3-5-haiku-20241022

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=

# Full service account JSON as a single-line escaped string.
# Generate with: cat firebase-service-account.json | jq -c .
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Database ──────────────────────────────────────────────────────────────────
# Local:      postgresql+asyncpg://postgres:password@localhost:5432/mealplanner
# Production: postgresql+asyncpg://{user}:{password}@{private-ip}/patrieats
DATABASE_URL=

# ── Redis (rate limiting) ─────────────────────────────────────────────────────
# Upstash TLS URL. Rate limiting is silently disabled when this is unset.
# Format: rediss://default:{token}@{host}:{port}
UPSTASH_REDIS_URL=

# ── Security ──────────────────────────────────────────────────────────────────
# Random 32-char string used to protect POST /internal/* endpoints.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production

# JSON array of allowed CORS origins. Must NOT contain localhost in production.
# Example: ["https://your-project.web.app","https://your-custom-domain.com"]
CORS_ORIGINS=

# Cloud Run service URL — used to validate OIDC token audience.
# Example: https://patrieats-backend-abc123-ew.a.run.app
CLOUD_RUN_URL=
